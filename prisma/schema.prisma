// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url dihapus sepenuhnya (sudah dipindah ke prisma.config.ts)
}

enum Role {
  admin
  user
}

enum UserStatus {
  active
  pending
  suspended
}

model User {
  id         String     @id @default(cuid()) // [cite: 32]
  name       String     // [cite: 33]
  email      String     @unique // [cite: 34]
  password   String     // [cite: 35]
  role       Role       @default(user) // [cite: 37]
  status     UserStatus @default(pending) // [cite: 38]
  createdAt  DateTime   @default(now()) // [cite: 40]
  
  // Relations
  tokens      Token[]      // 
  invitations Invitation[] // [cite: 62]
}

// 3.2. Token [cite: 41]
model Token {
  id          String   @id @default(cuid()) // [cite: 44]
  tokenCode   String   @unique // [cite: 45]
  isUsed      Boolean  @default(false) // [cite: 46]
  packageType String   // Misal: 'Basic', 'Premium' 
  createdAt   DateTime @default(now()) // 
  
  // Relations
  userId      String?  // 
  user        User?    @relation(fields: [userId], references: [id])
}

// 3.3. Template [cite: 48]
model Template {
  id           String   @id @default(cuid()) // [cite: 50]
  title        String   // [cite: 51]
  description  String?  @db.Text // [cite: 52]
  thumbnailUrl String?  // [cite: 53]
  previewUrl   String?  // [cite: 55]
  configPath   String   // [cite: 56]
  category     String   // [cite: 57]
  
  // Relations
  invitations  Invitation[] // [cite: 63]
}

// 3.4. Undangan (Invitation) [cite: 58]
model Invitation {
  id          String   @id @default(cuid()) // [cite: 60]
  title       String   // [cite: 64]
  slugUrl     String   @unique // [cite: 65]
  isActive    Boolean  @default(true) // [cite: 66]
  viewsCount  Int      @default(0) // [cite: 75]
  createdAt   DateTime @default(now()) // [cite: 76]

  /** * Content Data disimpan dalam format JSON untuk fleksibilitas [cite: 67]
   * Mencakup: mempelai_pria, mempelai_wanita, acara, love_story, gallery, 
   * digital_envelope, music_url, dan dress_code. [cite: 68, 69, 70, 71, 72, 73, 74]
   */
  contentData Json // [cite: 67]

  // Relations
  userId      String   // [cite: 62]
  user        User     @relation(fields: [userId], references: [id])
  templateId  String   // [cite: 63]
  template    Template @relation(fields: [templateId], references: [id])
  guestWishes GuestWish[] // [cite: 81]
}

// 3.5. Guest Wishes (Ucapan) [cite: 77]
enum Presence {
  Hadir
  Tidak_Hadir
  Ragu_ragu
}

model GuestWish {
  id           String   @id @default(cuid()) // [cite: 79]
  guestName    String   // [cite: 82]
  message      String   @db.Text // [cite: 83]
  isPresent    Presence // [cite: 84]
  createdAt    DateTime @default(now()) // [cite: 85]

  // Relations
  invitationId String   // [cite: 81]
  invitation   Invitation @relation(fields: [invitationId], references: [id])
}